{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tramoire",
  "version": "0.1.0",
  "identifier": "com.tramoire.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Tramoire",
        "width": 1440,
        "height": 900,
        "minWidth": 720,
        "minHeight": 520,
        "backgroundColor": "#17171b"
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
