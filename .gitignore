# Dependencies
node_modules/

# Build output
dist/
dist-ssr/

# Rust — reaches several gigabytes. If this is ever committed, the repo is ruined.
src-tauri/target/
src-tauri/gen/schemas/

# Manifest checkpoints — the copy taken before a project.json write. Recovery
# is by renaming one back by hand; they are never part of a commit.
.project.json.bak

# Claude Code local state — machine-specific tool permissions and the temp
# files it writes beside them. A shared .claude/settings.json is still fine.
.claude/settings.local.json
.claude/*.tmp.*

# Editors and OS
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
